    "sirv-cli": "^3.0.0"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^3.1.0",
    "@tsconfig/svelte": "^5.0.0",
    "autoprefixer": "^10.4.13",
    "concurrently": "^9.0.0",
    "json-server": "^0.17.1",
    "json-server-auth": "^2.1.0",
    "json-server-reset": "^1.3.3",
    "prettier": "^3.3.0",
    "query-string": "^9.0.0",
    "sass": "^1.77.0",
    "svelte": "^4.2.0",
    "svelte-check": "^3.8.0",
    "svelte-preprocess": "^5.1.0",
    "svelte-routing": "^2.13.0",
    "tslib": "^2.6.0",
