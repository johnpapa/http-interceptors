{
  "name": "angular-app",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --proxy-config proxy.conf.json --open --port 4202",
    "build": "ng build --configuration production",
    "test": "ng test",
    "lint": "ng lint",
    "full-stack": "concurrently \"npm run backend\" \"npm run start\"",
    "backend": "json-server-auth --watch db.json --routes routes.json --port 4302 --delay 1000 --middlewares ./node_modules/json-server-reset"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.0.0",
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/platform-browser-dynamic": "^21.0.0",
    "@angular/router": "^21.0.0",
    "@ngrx/effects": "^21.0.0",
    "@ngrx/entity": "^21.0.0",
    "@ngrx/store": "^21.0.0",
    "@ngrx/store-devtools": "^21.0.0",
    "@ngrx/data": "^21.0.0",
    "bulma": "^0.9.2",
    "font-awesome": "^4.7.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.0.0",
    "@angular/cli": "^21.0.0",
    "@angular/compiler-cli": "^21.0.0",
    "@angular/language-service": "^21.0.0",
    "concurrently": "^9.0.0",
    "json-server-auth": "^2.0.2",
    "json-server-reset": "^1.0.0",
    "source-map-explorer": "^2.5.2",
    "typescript": "~5.9.0"
  }
}
